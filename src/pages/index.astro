---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Auusda - Professional Laptop Manufacturer | Wholesale & Customization" description="Auusda is a professional laptop manufacturer offering high-quality laptops at competitive prices. We support wholesale and customization services for global customers.">
  <!-- Hero Section -->
  <section class="relative h-screen min-h-[600px] overflow-hidden bg-black flex items-center justify-center">
    <div class="relative z-10 text-center text-white px-4 max-w-4xl">
      <h1 class="text-4xl md:text-6xl font-bold mb-8">AUUSDA LAPTOP COMPANY</h1>
      <div class="text-xl md:text-2xl space-y-4">
        <p class="mb-4">For after-sales support, please contact us via email:</p>
        <p class="text-2xl md:text-3xl font-semibold text-yellow-400 mb-8">SupportUS@auusdalaptop.com</p>
        <p class="text-lg md:text-xl">Any questions? Feel free to reach out via email.</p>
        <p class="text-xl md:text-2xl font-medium mt-4">24/7 Customer Service Available</p>
      </div>
    </div>
  </section>

  <!-- Hidden Original Content -->
  <div class="hidden">
    <!-- About Us Section with Separate Images -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">About Auusda</h2>
          <p class="text-lg text-gray-600">
            Welcome to Auusda, where innovation meets affordability. Our mission is simple: to provide high-quality laptops at the most competitive prices.
          </p>
        </div>

        <div class="space-y-12">
          <div class="flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
              <img
                src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali2/kf/Hc27886ebe3a34812b94148522f9ffaccd.jpg"
                alt="Auusda Factory Warehouse"
                class="rounded-lg shadow-lg w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
            <div class="md:w-1/2">
              <h3 class="text-2xl font-semibold text-gray-900 mb-4">Global Laptop Brand</h3>
              <p class="text-gray-600 mb-4 leading-relaxed">
                Auusda is a global laptop brand under AUUSDA TEK CO., LIMITED, integrating both manufacturing and trade. What sets us apart is our unique ability to control the entire production process—from research and development to final assembly.
              </p>
              <p class="text-gray-600 leading-relaxed">
                Our factory, located in China, is equipped with state-of-the-art production facilities and a team of skilled professionals who ensure that every laptop we produce meets rigorous quality standards.
              </p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row-reverse items-center gap-12">
            <div class="md:w-1/2">
              <img
                src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali2/kf/H81ee249f79644d29ab0d5a803313f338R.jpg"
                alt="Auusda Workers Production"
                class="rounded-lg shadow-lg w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
            <div class="md:w-1/2">
              <h3 class="text-2xl font-semibold text-gray-900 mb-4">Skilled Professionals</h3>
              <p class="text-gray-600 mb-4 leading-relaxed">
                By combining manufacturing and sales, we eliminate unnecessary middlemen and offer you the best possible value without sacrificing performance or durability.
              </p>
              <p class="text-gray-600 leading-relaxed">
                With a commitment to excellence and customer satisfaction, Auusda strives to enhance the digital experience for students, professionals, and everyday users worldwide.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quality & Manufacturing Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Affordability Meets Quality</h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            At Auusda, quality is at the heart of everything we do. From material selection to final assembly, we ensure every laptop meets the highest standards.
          </p>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-12">
          <div class="md:w-1/2">
            <img
              src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali2/kf/H2d2a5fd65e6e41c2b22a3b9d8ebc09e2l.jpg"
              alt="Auusda Certifications"
              class="rounded-lg shadow-lg w-full h-auto object-cover"
              loading="lazy"
            />
          </div>
          <div class="md:w-1/2">
            <h3 class="text-2xl font-semibold text-gray-900 mb-4">Rigorous Quality Control</h3>
            <p class="text-gray-600 mb-6 leading-relaxed">
              Each device undergoes rigorous testing and quality control at our advanced production lines and testing labs, guaranteeing long-lasting reliability and exceptional performance. Our commitment to excellence ensures that every laptop delivers a seamless, reliable user experience, all while offering unbeatable value.
            </p>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <div>
                  <h4 class="font-semibold text-gray-900">State-of-the-Art Facilities</h4>
                  <p class="text-gray-600">Advanced production lines with cutting-edge technology</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <div>
                  <h4 class="font-semibold text-gray-900">Skilled Professionals</h4>
                  <p class="text-gray-600">Experienced team dedicated to quality craftsmanship</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-500 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <div>
                  <h4 class="font-semibold text-gray-900">Complete Production Control</h4>
                  <p class="text-gray-600">From R&D to final assembly, we control every step</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Collections Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Product Collections</h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            Explore our range of high-quality laptops and accessories, designed to meet diverse customer needs.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <a href="/products/laptops" class="group">
            <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 h-full">
              <div class="h-48 overflow-hidden">
                <img
                  src="https://auusda.store/cdn/shop/files/1-2.png?v=1747044003&width=800"
                  alt="14.1inch Laptops"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">14.1inch Laptops</h3>
                <p class="text-gray-600 mb-4">Compact and portable laptops for business and daily use</p>
                <div class="inline-flex items-center text-blue-600 font-medium">
                  <span>View Collection</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>

          <a href="/products/laptops-15-6inch" class="group">
            <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 h-full">
              <div class="h-48 overflow-hidden">
                <img
                  src="https://auusda.store/cdn/shop/files/1-4_273d7b72-f2dd-43da-b11b-a1eb0eb4fa58.png?v=1752055633&width=800"
                  alt="15.6inch Laptops"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-green-600 transition-colors">15.6inch Laptops</h3>
                <p class="text-gray-600 mb-4">Balanced performance for work and entertainment</p>
                <div class="inline-flex items-center text-green-600 font-medium">
                  <span>View Collection</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>

          <a href="/products/laptops-16inch" class="group">
            <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 h-full">
              <div class="h-48 overflow-hidden">
                <img
                  src="https://auusda.store/cdn/shop/files/1_75a66611-1c7c-4099-8881-c1a4e2eeb5ca.jpg?v=1761212959&width=800"
                  alt="16inch Laptops"
                  class="w-100 h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-purple-600 transition-colors">16inch Laptops</h3>
                <p class="text-gray-600 mb-4">Large display laptops for creative professionals</p>
                <div class="inline-flex items-center text-purple-600 font-medium">
                  <span>View Collection</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>

          <a href="/products/mini-pcs" class="group">
            <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 h-full">
              <div class="h-48 overflow-hidden">
                <img
                  src="https://auusda.store/cdn/shop/files/1_1cb8a640-9968-40d4-a3c5-594499508916.jpg?v=1748939804&width=800"
                  alt="Mini PCs & Chargers"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-orange-600 transition-colors">Mini PCs & Chargers</h3>
                <p class="text-gray-600 mb-4">Compact computing solutions and accessories</p>
                <div class="inline-flex items-center text-orange-600 font-medium">
                  <span>View Collection</span>
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </div>

        <div class="text-center mt-12">
          <a href="/products" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-md hover:bg-blue-700 transition-colors text-lg font-medium">
            View All Products
          </a>
        </div>
      </div>
    </section>

    <!-- Mission & CTA Section -->
    <section class="py-16 bg-gradient-to-r from-blue-600 to-blue-800 text-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-6">Our Mission</h2>
          <p class="text-lg mb-8 leading-relaxed">
            We believe that high-quality technology should be accessible to everyone. That's why we focus on creating laptops that offer outstanding performance at an unbeatable price. Whether you're a student, a professional, or a casual user, our products are designed to enhance your digital experience without breaking the bank.
          </p>
          <p class="text-lg mb-8 leading-relaxed">
            At Auusda, we are more than just a laptop brand—we are a technology partner committed to empowering your digital journey. Join us and experience the future of affordable, high-performance computing today!
          </p>
          <a href="/contact" class="inline-block bg-white text-blue-700 px-8 py-3 rounded-md hover:bg-gray-100 transition-colors text-lg font-medium">
            Get in Touch
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>