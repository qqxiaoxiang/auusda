---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us - Auusda" description="Learn about Auusda, a global laptop brand integrating manufacturing and trade, offering high-quality laptops at unbeatable value">
  <!-- Hero Banner Section -->
  <section class="relative w-full h-[50vh] min-h-[400px] overflow-hidden">
    <img 
      src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali//@sc02/kf/H815e2b17528449cea027e85b07db3e94t.jpg?hasNWGrade=" 
      alt="Auusda Laptop Manufacturing" 
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end">
      <div class="container mx-auto px-4 py-16 text-white">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">About Auusda</h1>
        <p class="text-lg md:text-xl max-w-3xl">A global laptop brand integrating manufacturing and trade, delivering high-quality devices at unbeatable value</p>
      </div>
    </div>
  </section>

  <!-- Company Overview Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Who We Are</h2>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            Auusda is a global laptop brand under AUUSDA TEK CO., LIMITED, integrating both manufacturing and trade. What sets us apart is our unique ability to control the entire production process—from research and development to final assembly.
          </p>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            Our factory, located in China, is equipped with state-of-the-art production facilities and a team of skilled professionals who ensure that every laptop we produce meets rigorous quality standards. By combining manufacturing and sales, we eliminate unnecessary middlemen and offer you the best possible value without sacrificing performance or durability.
          </p>
          <div class="bg-blue-50 p-6 rounded-lg border-l-4 border-blue-600">
            <p class="text-gray-700 italic">
              "High-quality technology should be accessible to everyone. That's why we focus on creating laptops that offer outstanding performance at an unbeatable price."
            </p>
          </div>
        </div>
        <div class="rounded-lg overflow-hidden shadow-xl">
          <img 
            src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali/@sc02/kf/H5de2bc2f672f40a387607667f96be2c1n.jpg?hasNWGrade=" 
            alt="Auusda Laptop Products" 
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Manufacturing Excellence Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Our Manufacturing Excellence</h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-lg overflow-hidden shadow-xl order-2 lg:order-1">
          <img 
            src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali2/kf/H80a9ebe2a5084153b9e39a4113e56c67r/284489714/H80a9ebe2a5084153b9e39a4113e56c67r.jpg" 
            alt="Auusda Factory Production Line" 
            class="w-full h-auto object-cover"
          />
        </div>
        <div class="order-1 lg:order-2">
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">End-to-End Production Control</h3>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            At Auusda, we take pride in controlling every aspect of the manufacturing process. From initial design and component sourcing to final assembly and quality testing, our team of experts ensures precision and consistency at every step.
          </p>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            Our advanced production facilities feature cutting-edge technology and automated assembly lines, while our skilled technicians oversee every detail to guarantee that each laptop meets our exacting standards.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white p-5 rounded-lg shadow-md">
              <div class="text-blue-600 font-bold text-2xl mb-2">100%</div>
              <p class="text-gray-700">In-House Production</p>
            </div>
            <div class="bg-white p-5 rounded-lg shadow-md">
              <div class="text-blue-600 font-bold text-2xl mb-2">500K+</div>
              <p class="text-gray-700">Annual Production</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quality Commitment Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Our Commitment to Quality</h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">Rigorous Testing & Quality Control</h3>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            Quality is at the heart of everything we do at Auusda. From material selection to final assembly, we ensure every laptop meets the highest industry standards.
          </p>
          <p class="text-gray-600 mb-6 text-lg leading-relaxed">
            Each device undergoes comprehensive testing in our advanced labs, including performance benchmarks, durability tests, and reliability assessments. Our quality control team inspects every laptop to guarantee long-lasting reliability and exceptional performance.
          </p>
          <ul class="space-y-4">
            {[
              "Advanced testing facilities",
              "Stringent quality control processes",
              "Certified components",
              "Long-term reliability testing"
            ].map((item, index) => (
              <li key={index} class="flex items-center">
                <svg class="w-6 h-6 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-gray-700 text-lg">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-lg overflow-hidden shadow-xl">
          <img 
            src="https://res.cloudinary.com/dcfcz3rvj/image/upload/f_auto,q_auto/ali2/kf/He2ad3c55b43845f493013267b869b20b6.png" 
            alt="Auusda Quality Certifications" 
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values Section -->
  <section class="py-20 bg-blue-600 text-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Our Core Values</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-lg text-center hover:bg-white/20 transition-colors">
          <div class="bg-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4">Quality First</h3>
          <p class="opacity-90">We never compromise on quality, ensuring every product meets our rigorous standards.</p>
        </div>
        
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-lg text-center hover:bg-white/20 transition-colors">
          <div class="bg-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4">Customer Focus</h3>
          <p class="opacity-90">Our customers are at the center of everything we do, guiding our innovation and service.</p>
        </div>
        
        <div class="bg-white/10 backdrop-blur-sm p-8 rounded-lg text-center hover:bg-white/20 transition-colors">
          <div class="bg-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-4">Value Creation</h3>
          <p class="opacity-90">We deliver exceptional value by combining manufacturing efficiency with innovative design.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Impact Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Our Global Impact</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {[
          { number: "50+", label: "Countries Served" },
          { number: "100K+", label: "Happy Customers" },
          { number: "100%", label: "Customer Satisfaction" }
        ].map((stat, index) => (
          <div key={index} class="text-center p-8 bg-gray-50 rounded-lg shadow-md hover:shadow-lg transition-shadow">
            <div class="text-4xl md:text-5xl font-bold text-blue-600 mb-2">{stat.number}</div>
            <div class="text-gray-700 text-lg">{stat.label}</div>
          </div>
        ))}
      </div>
      
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-gray-600 text-lg leading-relaxed">
          Whether you're a student, a professional, or a casual user, our laptops are designed to enhance your digital experience without breaking the bank. Join thousands of satisfied customers worldwide who trust Auusda for their computing needs.
        </p>
        <a 
          href="/products" 
          class="inline-block mt-8 bg-blue-600 text-white px-8 py-3 rounded-md hover:bg-blue-700 transition-colors text-lg font-medium"
        >
          Explore Our Products
        </a>
      </div>
    </div>
  </section>
</Layout>