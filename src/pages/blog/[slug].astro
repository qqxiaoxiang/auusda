---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blogPosts.js';

// Generate static paths for all blog posts
export function getStaticPaths() {
  return Object.keys(blogPosts).map(slug => ({
    params: { slug }
  }));
}

// Get the slug from params
const { slug } = Astro.params;

// Find the post with matching slug
const post = blogPosts[slug];

// If post not found, redirect to 404
if (!post) {
  Astro.redirect('/404', 302);
}

// Generate structured data for SEO
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt,
  image: post.image,
  datePublished: post.date,
  dateModified: post.date,
  author: {
    '@type': 'Person',
    name: post.author
  },
  publisher: {
    '@type': 'Organization',
    name: 'Auusda',
    logo: {
      '@type': 'ImageObject',
      url: 'https://res.cloudinary.com/dcfcz3rvj/image/upload/v1768364985/c6534fd5-f7e9-4846-8f25-3d45683e6ac1_ejoljb.png'
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://www.auusda.com/blog/${slug}`
  }
};
---

<Layout 
  title={`${post.title} - Auusda Blog`} 
  description={post.excerpt}
>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json">
    {JSON.stringify(structuredData)}
  </script>

  <!-- Blog Post Hero -->
  <section class="relative w-full h-[40vh] min-h-[300px] overflow-hidden">
    <img 
      src={post.image} 
      alt={post.title} 
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end">
      <div class="container mx-auto px-4 py-16 text-white">
        <div class="flex items-center text-sm mb-3">
          <span class="mr-4">{post.date}</span>
          <span class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">{post.category}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold mb-3">{post.title}</h1>
        <div class="flex items-center">
          <span class="text-white/90">By {post.author}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Post Content -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Main Content -->
        <article class="lg:col-span-8 prose prose-lg max-w-none">
          <!-- Content will be rendered here -->
          <div set:html={post.content}></div>
        </article>
        
        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <!-- Author Info -->
          <div class="bg-gray-50 rounded-lg p-6 mb-8">
            <h3 class="text-lg font-semibold mb-4">About the Author</h3>
            <div class="flex items-center space-x-4">
              <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 font-semibold">{post.author.charAt(0)}</span>
              </div>
              <div>
                <h4 class="font-medium">{post.author}</h4>
                <p class="text-sm text-gray-600">Tech expert with years of experience in the laptop industry</p>
              </div>
            </div>
          </div>
          
          <!-- Categories -->
          <div class="bg-gray-50 rounded-lg p-6 mb-8">
            <h3 class="text-lg font-semibold mb-4">Categories</h3>
            <ul class="space-y-2">
              <li>
                <a href="#" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
                  <span class="mr-2">📱</span> Brand Review
                </a>
              </li>
              <li>
                <a href="#" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
                  <span class="mr-2">🏭</span> Manufacturing
                </a>
              </li>
              <li>
                <a href="#" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
                  <span class="mr-2">⭐</span> Product Review
                </a>
              </li>
              <li>
                <a href="#" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
                  <span class="mr-2">🇺🇸</span> US Market
                </a>
              </li>
              <li>
                <a href="#" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
                  <span class="mr-2">🏢</span> Corporate
                </a>
              </li>
              <li>
                <a href="#" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
                  <span class="mr-2">🎒</span> Accessories
                </a>
              </li>
            </ul>
          </div>
          
          <!-- Recent Posts -->
          <div class="bg-gray-50 rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-4">Recent Posts</h3>
            <ul class="space-y-4">
              {Object.entries(blogPosts).slice(0, 3).map(([recentSlug, recentPost], index) => (
                <li key={index} class="flex space-x-3">
                  <div class="w-16 h-16 rounded overflow-hidden flex-shrink-0">
                    <img 
                      src={recentPost.image} 
                      alt={recentPost.title} 
                      class="w-full h-full object-cover"
                    />
                  </div>
                  <div>
                    <a 
                      href={`/blog/${recentSlug}`} 
                      class="text-sm font-medium hover:text-blue-600 transition-colors"
                    >
                      {recentPost.title}
                    </a>
                    <p class="text-xs text-gray-500 mt-1">{recentPost.date}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">Related Posts</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {Object.entries(blogPosts).filter(([relatedSlug, p]) => relatedSlug !== slug).slice(0, 3).map(([relatedSlug, relatedPost], index) => (
          <article key={index} class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="h-40 overflow-hidden">
              <img 
                src={relatedPost.image} 
                alt={relatedPost.title} 
                class="w-full h-full object-cover transition-transform hover:scale-105"
              />
            </div>
            <div class="p-5">
              <div class="flex items-center text-sm text-gray-500 mb-2">
                <span>{relatedPost.date}</span>
              </div>
              <h3 class="font-semibold mb-2">
                <a href={`/blog/${relatedSlug}`} class="text-gray-900 hover:text-blue-600 transition-colors">
                  {relatedPost.title}
                </a>
              </h3>
              <a 
                href={`/blog/${relatedSlug}`} 
                class="inline-flex items-center text-blue-600 text-sm font-medium hover:text-blue-800"
              >
                Read More
                <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comment Section -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8">Leave a Comment</h2>
      <div class="max-w-3xl">
        <form class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input type="text" id="name" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" id="email" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
            </div>
          </div>
          <div>
            <label for="comment" class="block text-sm font-medium text-gray-700 mb-1">Comment</label>
            <textarea id="comment" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required></textarea>
          </div>
          <div>
            <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-md hover:bg-blue-700 transition-colors font-medium">
              Submit Comment
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Blog post specific styles */
  .prose {
    max-width: 100%;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  
  .prose h1 {
    color: #1a202c;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }
  
  .prose h2 {
    color: #2d3748;
    font-weight: 700;
    font-size: 2rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #e2e8f0;
    line-height: 1.3;
  }
  
  .prose h3 {
    color: #4a5568;
    font-weight: 600;
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }
  
  .prose p {
    color: #4a5568;
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    text-align: justify;
  }
  
  .prose p:first-of-type {
    font-size: 1.15rem;
    font-weight: 500;
    color: #2d3748;
  }
  
  .prose img {
    display: block;
    margin: 2.5rem auto;
    border-radius: 0.75rem;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    transition: transform 0.3s ease;
    max-width: 100%;
    height: auto;
  }
  
  .prose img:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15), 0 10px 10px -5px rgba(0, 0, 0, 0.06);
  }
  
  .prose ul {
    margin: 1.5rem 0;
    padding-left: 1.75rem;
  }
  
  .prose li {
    color: #4a5568;
    line-height: 1.8;
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
  }
  
  .prose li strong {
    color: #2d3748;
  }
  
  /* Sidebar styles */
  aside h3 {
    color: #2d3748;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #e2e8f0;
  }
  
  aside ul li {
    transition: all 0.2s ease;
  }
  
  aside ul li:hover {
    transform: translateX(4px);
  }
  
  /* Recent posts */
  .recent-posts li {
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  
  .recent-posts li:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }
  
  .recent-posts a {
    color: #2d3748;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  
  .recent-posts a:hover {
    color: #3182ce;
  }
  
  /* Related posts */
  .related-posts article {
    transition: all 0.3s ease;
    border: 1px solid #e2e8f0;
  }
  
  .related-posts article:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15), 0 10px 10px -5px rgba(0, 0, 0, 0.06);
  }
  
  .related-posts h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  
  /* Comment form */
  form input, form textarea {
    transition: all 0.2s ease;
    border: 1px solid #e2e8f0;
  }
  
  form input:focus, form textarea:focus {
    outline: none;
    border-color: #3182ce;
    box-shadow: 0 0 0 3px rgba(49, 130, 206, 0.1);
  }
  
  form label {
    font-weight: 500;
    color: #4a5568;
  }
  
  /* Author info */
  .author-info {
    background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
    border-radius: 0.75rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }
  
  /* Categories */
  .categories-list a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }
  
  .categories-list a:hover {
    background-color: #ebf8ff;
    color: #2b6cb0;
  }
  
  /* Blog post hero */
  .blog-hero {
    position: relative;
    overflow: hidden;
  }
  
  .blog-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.2) 50%, transparent 100%);
    z-index: 1;
  }
  
  .blog-hero-content {
    position: relative;
    z-index: 2;
  }
  
  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .lg\:col-span-8,
    .lg\:col-span-4 {
      grid-column: span 12;
    }
    
    aside {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 2px solid #e2e8f0;
    }
  }
  
  @media (max-width: 768px) {
    .prose h1 {
      font-size: 2.25rem;
    }
    
    .prose h2 {
      font-size: 1.75rem;
      margin-top: 2.5rem;
    }
    
    .prose h3 {
      font-size: 1.375rem;
    }
    
    .prose p {
      font-size: 1rem;
    }
    
    .prose p:first-of-type {
      font-size: 1.05rem;
    }
  }
  
  @media (max-width: 480px) {
    .prose h1 {
      font-size: 2rem;
    }
    
    .prose h2 {
      font-size: 1.5rem;
      margin-top: 2rem;
    }
    
    .prose h3 {
      font-size: 1.25rem;
    }
    
    .py-12 {
      padding: 2rem 0;
    }
    
    .p-6 {
      padding: 1.25rem;
    }
  }
</style>