---
interface Props {
  showModal?: boolean;
}

const { showModal = false } = Astro.props;
---

<!-- Form container -->
<div id="inquiry-form-wrapper">
  <!-- Modal Background - Always render but hidden by default -->
  <div id="inquiryModal" class="fixed inset-0 bg-black/70 flex items-center justify-center z-50 transition-opacity duration-300 opacity-0 pointer-events-none">
    <div class="max-w-2xl w-full mx-auto bg-white rounded-lg shadow-2xl overflow-hidden transform transition-all duration-300 scale-95">
      <!-- Modal Header -->
      <div class="bg-blue-600 text-white p-6 flex justify-between items-center">
        <h2 class="text-2xl font-bold">Send Inquiry</h2>
        <button 
          class="text-white hover:text-gray-200 transition-colors"
          onclick="document.getElementById('inquiryModal').classList.remove('show')"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <!-- Modal Content -->
      <div class="p-6">
        <!-- Success Message -->
        <div class="modal-success-message hidden text-center py-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2">Inquiry Submitted Successfully!</h3>
          <p class="modal-success-message-text text-gray-600 mb-6"></p>
          <button 
            class="px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
            onclick="document.getElementById('inquiryModal')?.classList.remove('show')"
          >
            Close
          </button>
        </div>
        
        <!-- Form -->
        <form class="modal-form">
          <h3 class="text-xl font-bold text-gray-800 mb-6">Send Us an Inquiry</h3>
          
          <!-- Error Message -->
          <div class="modal-error-message mb-4 p-3 bg-red-100 text-red-700 rounded-lg hidden"></div>
          
          <!-- Form Fields -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <!-- Name Field -->
            <div>
              <label for="modal-name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
              <input
                type="text"
                id="modal-name"
                name="name"
                class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
                placeholder="Your full name"
              />
              <p class="modal-name-error text-red-500 text-xs mt-1 hidden"></p>
            </div>
            
            <!-- Country Field -->
            <div>
              <label for="modal-country" class="block text-sm font-medium text-gray-700 mb-1">Country *</label>
              <input
                type="text"
                id="modal-country"
                name="country"
                class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
                placeholder="Your country"
              />
              <p class="modal-country-error text-red-500 text-xs mt-1 hidden"></p>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <!-- Phone Field -->
            <div>
              <label for="modal-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone/WhatsApp *</label>
              <input
                type="tel"
                id="modal-phone"
                name="phone"
                class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
                placeholder="Your phone number"
              />
              <p class="modal-phone-error text-red-500 text-xs mt-1 hidden"></p>
            </div>
            
            <!-- Email Field -->
            <div>
              <label for="modal-email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
              <input
                type="email"
                id="modal-email"
                name="email"
                class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
                placeholder="Your email address"
              />
              <p class="modal-email-error text-red-500 text-xs mt-1 hidden"></p>
            </div>
          </div>
          
          <!-- Message Field -->
          <div class="mb-4">
            <label for="modal-message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
            <textarea
              id="modal-message"
              name="message"
              rows="5"
              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none border-gray-300"
              placeholder="Your message here..."></textarea>
              <p class="modal-message-error text-red-500 text-xs mt-1 hidden"></p>
          </div>
          
          <!-- Submit Button -->
          <div class="flex justify-end">
            <button
              type="submit"
              class="modal-submit-button px-8 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-all flex items-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
            >
              <span class="modal-button-text">Send Inquiry</span>
              <svg class="modal-loading-spinner animate-spin -ml-1 mr-2 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
  
  <!-- Inline Form only shown if not in modal mode -->
  {!showModal && (
    <div class="max-w-2xl w-full mx-auto p-6">
      <!-- Success Message -->
      <div class="inline-success-message hidden text-center py-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-2">Inquiry Submitted Successfully!</h3>
        <p class="inline-success-message-text text-gray-600 mb-6"></p>
      </div>
      
      <!-- Form -->
      <form class="inline-form">
        <h3 class="text-xl font-bold text-gray-800 mb-6">Send Us an Inquiry</h3>
        
        <!-- Error Message -->
        <div class="inline-error-message mb-4 p-3 bg-red-100 text-red-700 rounded-lg hidden"></div>
        
        <!-- Form Fields -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <!-- Name Field -->
          <div>
            <label for="inline-name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
            <input
              type="text"
              id="inline-name"
              name="name"
              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
              placeholder="Your full name"
            />
            <p class="inline-name-error text-red-500 text-xs mt-1 hidden"></p>
          </div>
          
          <!-- Country Field -->
          <div>
            <label for="inline-country" class="block text-sm font-medium text-gray-700 mb-1">Country *</label>
            <input
              type="text"
              id="inline-country"
              name="country"
              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
              placeholder="Your country"
            />
            <p class="inline-country-error text-red-500 text-xs mt-1 hidden"></p>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <!-- Phone Field -->
          <div>
            <label for="inline-phone" class="block text-sm font-medium text-gray-700 mb-1">Phone/WhatsApp *</label>
            <input
              type="tel"
              id="inline-phone"
              name="phone"
              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
              placeholder="Your phone number"
            />
            <p class="inline-phone-error text-red-500 text-xs mt-1 hidden"></p>
          </div>
          
          <!-- Email Field -->
          <div>
            <label for="inline-email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
            <input
              type="email"
              id="inline-email"
              name="email"
              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all border-gray-300"
              placeholder="Your email address"
            />
            <p class="inline-email-error text-red-500 text-xs mt-1 hidden"></p>
          </div>
        </div>
        
        <!-- Message Field -->
        <div class="mb-4">
          <label for="inline-message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
          <textarea
            id="inline-message"
            name="message"
            rows="5"
            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none border-gray-300"
            placeholder="Your message here..."></textarea>
            <p class="inline-message-error text-red-500 text-xs mt-1 hidden"></p>
        </div>
        
        <!-- Submit Button -->
        <div class="flex justify-end">
          <button
            type="submit"
            class="inline-submit-button px-8 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-all flex items-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
          >
            <span class="inline-button-text">Send Inquiry</span>
            <svg class="inline-loading-spinner animate-spin -ml-1 mr-2 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </div>
      </form>
    </div>
  )}
</div>

<!-- Modal show script -->
<script define:vars={{ showModal }}>
  // Show modal if showModal prop is true
  if (showModal) {
    const modal = document.getElementById('inquiryModal');
    if (modal) {
      modal.classList.add('show');
    }
  }
</script>

<!-- JavaScript for form functionality -->
<script>
  // Simple and direct form functionality
  document.addEventListener('DOMContentLoaded', function() {
    // Get modal element first
    const inquiryModal = document.getElementById('inquiryModal');
    if (!inquiryModal) return;
    
    // Function to show modal
    const showModal = () => {
      inquiryModal.classList.add('show');
    };
    
    // Function to hide modal
    const hideModal = () => {
      inquiryModal.classList.remove('show');
    };
    
    // Add click event listeners to all buttons with header-get-quote-btn class
    const quoteButtons = document.querySelectorAll('.header-get-quote-btn');
    quoteButtons.forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        showModal();
      });
    });
    
    // Add click event listener to all Get Quote buttons by text content
    const allButtons = document.querySelectorAll('button');
    allButtons.forEach(button => {
      const text = button.textContent.trim().toLowerCase();
      if (text.includes('get quote') || text.includes('request custom quote') || text.includes('send request')) {
        button.addEventListener('click', function(e) {
          e.preventDefault();
          showModal();
        });
      }
    });
    
    // Add click event listener to the close button (X)
    const closeButton = inquiryModal.querySelector('.text-white.hover:text-gray-200');
    if (closeButton) {
      closeButton.addEventListener('click', function(e) {
        e.stopPropagation();
        hideModal();
      });
    }
    
    // Add click event listener to the Close button in success message
    const allModalButtons = inquiryModal.querySelectorAll('button');
    allModalButtons.forEach(btn => {
      if (btn.textContent.trim() === 'Close') {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          hideModal();
        });
      }
    });
    
    // Close modal when clicking on background
    inquiryModal.addEventListener('click', function(e) {
      if (e.target === inquiryModal) {
        hideModal();
      }
    });
    
    // Close modal when ESC key is pressed
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && inquiryModal.classList.contains('show')) {
        hideModal();
      }
    });
    
    // Form functionality remains unchanged
    // Get all forms
    const forms = document.querySelectorAll('.modal-form, .inline-form');
    
    forms.forEach(form => {
      // Get form type (modal or inline)
      const formType = form.classList.contains('modal-form') ? 'modal' : 'inline';
      
      // Get elements
      const successMessage = form.parentElement.querySelector(`.${formType}-success-message`);
      const successMessageText = form.parentElement.querySelector(`.${formType}-success-message-text`);
      const errorMessage = form.querySelector(`.${formType}-error-message`);
      const submitButton = form.querySelector(`.${formType}-submit-button`);
      const buttonText = form.querySelector(`.${formType}-button-text`);
      const loadingSpinner = form.querySelector(`.${formType}-loading-spinner`);
      
      // Get fields
      const nameInput = form.querySelector(`#${formType}-name`);
      const countryInput = form.querySelector(`#${formType}-country`);
      const phoneInput = form.querySelector(`#${formType}-phone`);
      const emailInput = form.querySelector(`#${formType}-email`);
      const messageInput = form.querySelector(`#${formType}-message`);
      
      // Get error elements
      const nameError = form.querySelector(`.${formType}-name-error`);
      const countryError = form.querySelector(`.${formType}-country-error`);
      const phoneError = form.querySelector(`.${formType}-phone-error`);
      const emailError = form.querySelector(`.${formType}-email-error`);
      const messageError = form.querySelector(`.${formType}-message-error`);
      
      // Reset errors
      const resetErrors = () => {
        [nameError, countryError, phoneError, emailError, messageError].forEach(error => {
          if (error) error.classList.add('hidden');
        });
        [nameInput, countryInput, phoneInput, emailInput, messageInput].forEach(input => {
          if (input) {
            input.classList.remove('border-red-500');
            input.classList.add('border-gray-300');
          }
        });
        if (errorMessage) errorMessage.classList.add('hidden');
      };
      
      // Show error
      const showError = (errorElement, inputElement, message) => {
        if (errorElement && inputElement) {
          errorElement.textContent = message;
          errorElement.classList.remove('hidden');
          inputElement.classList.remove('border-gray-300');
          inputElement.classList.add('border-red-500');
        }
      };
      
      // Validate form
      const validateForm = () => {
        resetErrors();
        let isValid = true;
        
        if (!nameInput.value.trim()) { showError(nameError, nameInput, 'Name is required'); isValid = false; }
        if (!countryInput.value.trim()) { showError(countryError, countryInput, 'Country is required'); isValid = false; }
        if (!phoneInput.value.trim()) { showError(phoneError, phoneInput, 'Phone/WhatsApp is required'); isValid = false; }
        if (!emailInput.value.trim()) { 
          showError(emailError, emailInput, 'Email is required'); 
          isValid = false; 
        } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
          showError(emailError, emailInput, 'Please enter a valid email address');
          isValid = false;
        }
        if (!messageInput.value.trim()) { showError(messageError, messageInput, 'Message is required'); isValid = false; }
        
        return isValid;
      };
      
      // Show success message
      const showSuccess = (message) => {
        if (successMessage && successMessageText) {
          successMessageText.textContent = message;
          successMessage.classList.remove('hidden');
          form.classList.add('hidden');
        }
      };
      
      // Show general error
      const showGeneralError = (message) => {
        if (errorMessage) {
          errorMessage.textContent = message;
          errorMessage.classList.remove('hidden');
        }
      };
      
      // Handle input changes
      [nameInput, countryInput, phoneInput, emailInput, messageInput].forEach(input => {
        if (input) {
          input.addEventListener('input', () => {
            const fieldName = input.id.replace(`${formType}-`, '');
            const errorElement = form.querySelector(`.${formType}-${fieldName}-error`);
            if (errorElement) {
              errorElement.classList.add('hidden');
              input.classList.remove('border-red-500');
              input.classList.add('border-gray-300');
            }
            if (errorMessage && !errorMessage.classList.contains('hidden')) {
              errorMessage.classList.add('hidden');
            }
          });
        }
      });
      
      // Handle form submission
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!validateForm()) return;
        
        // Show loading
        if (buttonText && loadingSpinner) {
          buttonText.textContent = 'Sending...';
          loadingSpinner.classList.remove('hidden');
        }
        if (submitButton) submitButton.disabled = true;
        
        try {
          // Get form data
          const formData = {
            name: nameInput.value.trim(),
            country: countryInput.value.trim(),
            phone: phoneInput.value.trim(),
            email: emailInput.value.trim(),
            message: messageInput.value.trim(),
            pageUrl: window.location.href
          };
          
          // Submit data
          const response = await fetch('https://form1.ailujiaxiang.workers.dev/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
          });
          
          const result = await response.json();
          
          if (response.ok) {
            showSuccess('Thank you for your inquiry! We will get back to you soon.');
            form.reset();
          } else {
            showGeneralError(result.error || 'Failed to submit inquiry. Please try again later.');
          }
        } catch (error) {
          showGeneralError('An error occurred. Please check your internet connection and try again.');
        } finally {
          // Reset button
          if (buttonText && loadingSpinner) {
            buttonText.textContent = 'Send Inquiry';
            loadingSpinner.classList.add('hidden');
          }
          if (submitButton) submitButton.disabled = false;
        }
      });
    });
  });
</script>

<style>
  /* Modal styles */
  #inquiryModal {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  
  #inquiryModal.show {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }
  
  #inquiryModal > div {
    transform: scale(0.95);
    transition: transform 0.3s ease;
  }
  
  #inquiryModal.show > div {
    transform: scale(1);
  }
  
  /* Form styles */
  form {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }
  
  input,
  textarea {
    font-family: inherit;
    font-size: 1rem;
  }
  
  input:focus,
  textarea:focus {
    outline: none;
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    #inquiryModal {
      padding: 1rem;
    }
    
    #inquiryModal > div {
      margin: 0;
      max-width: 100%;
    }
    
    .p-6 {
      padding: 1.5rem;
    }
    
    h3.text-xl {
      font-size: 1.25rem;
    }
    
    .grid-cols-1.md\:grid-cols-2 {
      grid-template-columns: 1fr;
    }
    
    button[type="submit"] {
      width: 100%;
      justify-content: center;
    }
  }
  
  @media (max-width: 480px) {
    #inquiryModal > div {
      margin: 0.5rem;
    }
    
    .p-6 {
      padding: 1.25rem;
    }
    
    h3.text-xl {
      font-size: 1.125rem;
      margin-bottom: 1rem;
    }
    
    input,
    textarea {
      padding: 0.75rem;
    }
    
    button[type="submit"] {
      padding: 0.75rem 1.5rem;
    }
  }
</style>
