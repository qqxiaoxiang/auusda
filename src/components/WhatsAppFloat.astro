  href={whatsappUrl} 
  target="_blank" 
  rel="noopener noreferrer" 
  class="whatsapp-float"
  aria-label="Chat with us on WhatsApp"
  title="Chat with us on WhatsApp"
>
  <div class="whatsapp-icon">
