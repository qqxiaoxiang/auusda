---
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="container mx-auto px-4 py-4">
    <div class="flex justify-between items-center">
      <!-- Logo Hidden -->
      <div class="hidden">
        <a href="/" class="flex items-center">
          <img
            src="https://res.cloudinary.com/dcfcz3rvj/image/upload/v1768364985/c6534fd5-f7e9-4846-8f25-3d45683e6ac1_ejoljb.png"
            alt="Auusda Logo"
            class="h-12 w-auto object-contain"
          />
        </a>
      </div>

      <!-- Header Message -->
      <div class="w-full text-center">
        <p class="text-gray-700 text-sm md:text-base">
          We are a laptop battery factory. If you need laptop batteries, please contact us via <span class="font-semibold text-blue-600">Get Quote</span>.
        </p>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Home</a>
        <button class="header-get-quote-btn bg-blue-600 text-white px-5 py-2 rounded-md hover:bg-blue-700 transition-colors font-medium">
          Get Quote
        </button>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        class="md:hidden text-gray-700 hover:text-blue-600 focus:outline-none"
        id="mobile-menu-button"
      >
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
      <div class="md:hidden mt-4 space-y-3" id="mobile-menu" style="display: none;">
        <a href="/" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Home</a>
        <button class="header-get-quote-btn w-full bg-blue-600 text-white px-5 py-3 rounded-md hover:bg-blue-700 transition-colors font-medium">
          Get Quote
        </button>
      </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.style.display = mobileMenu.style.display === 'block' ? 'none' : 'block';
    });
  }
</script>