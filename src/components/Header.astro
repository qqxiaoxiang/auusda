---
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="container mx-auto px-4 py-4">
    <div class="flex justify-between items-center">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img 
          src="https://res.cloudinary.com/dcfcz3rvj/image/upload/v1768364985/c6534fd5-f7e9-4846-8f25-3d45683e6ac1_ejoljb.png" 
          alt="Auusda Logo" 
          class="h-12 w-auto object-contain"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Home</a>
        
        <!-- Products Dropdown -->
        <div class="relative group">
          <button class="flex items-center text-gray-700 hover:text-blue-600 font-medium transition-colors">
            Products
            <svg class="w-4 h-4 ml-1 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg py-2 z-50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <a href="/products" class="block px-4 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">All Products</a>
            <a href="/products/laptops" class="block px-4 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">14.1inch Laptops</a>
            <a href="/products/laptops-15-6inch" class="block px-4 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">15.6inch Laptops</a>
            <a href="/products/laptops-16inch" class="block px-4 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">16inch Laptops</a>
            <a href="/products/mini-pcs" class="block px-4 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">Mini PCs</a>
            <a href="/products/chargers" class="block px-4 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors">Chargers</a>
          </div>
        </div>
        
        <a href="/about" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">About Us</a>
        <a href="/contact" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Contact Us</a>
        <a href="/blog" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Blogs</a>
        <a href="/custom-solutions" class="text-gray-700 hover:text-blue-600 font-medium transition-colors">Custom Solutions</a>
        <button class="header-get-quote-btn bg-blue-600 text-white px-5 py-2 rounded-md hover:bg-blue-700 transition-colors font-medium">
          Get Quote
        </button>
      </nav>

      <!-- Mobile Menu Button -->
      <button 
        class="md:hidden text-gray-700 hover:text-blue-600 focus:outline-none"
        id="mobile-menu-button"
      >
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
      <div class="md:hidden mt-4 space-y-3" id="mobile-menu" style="display: none;">
        <a href="/" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Home</a>
        
        <!-- Products with submenu for mobile -->
        <div class="space-y-2">
          <a href="/products" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Products</a>
          <div class="pl-6 space-y-2">
            <a href="/products/laptops" class="block px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">14.1inch Laptops</a>
            <a href="/products/laptops-15-6inch" class="block px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">15.6inch Laptops</a>
            <a href="/products/laptops-16inch" class="block px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">16inch Laptops</a>
            <a href="/products/mini-pcs" class="block px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Mini PCs</a>
            <a href="/products/chargers" class="block px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Chargers</a>
          </div>
        </div>
        
        <a href="/about" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">About Us</a>
        <a href="/contact" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Contact Us</a>
        <a href="/blog" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Blogs</a>
        <a href="/custom-solutions" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md text-gray-700 hover:text-blue-600 font-medium transition-colors">Custom Solutions</a>
        <button class="header-get-quote-btn w-full bg-blue-600 text-white px-5 py-3 rounded-md hover:bg-blue-700 transition-colors font-medium">
          Get Quote
        </button>
      </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.style.display = mobileMenu.style.display === 'block' ? 'none' : 'block';
    });
  }
</script>